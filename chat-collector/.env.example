# Chat Collector Configuration
# Copy this file to .env.local (stub) or .env.prod (real server) and edit values.
# Then run: npm run dev:local  OR  npm run dev:prod

# --- Stub mode (chat-stubs) ---
# CHAT_WS_URL=ws://localhost:3001/ws/chat
# CHAT_API_KEY=local-dev-key
# CHAT_ROOMS=#test

# --- Real server mode ---
# CHAT_WS_URL=wss://sinair.net/ws/chat
# CHAT_API_KEY=<your-api-key-from-sinair.net-profile>
# CHAT_ROOMS=#chat

CHAT_WS_URL=
CHAT_API_KEY=
CHAT_ROOMS=

BACKEND_URL=http://localhost:8080/api/chat/ingest
BATCH_SIZE=10
BATCH_FLUSH_INTERVAL=5000
