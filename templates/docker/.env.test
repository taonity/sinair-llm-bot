COMPOSE_ENV_FILE=.env.test
DOCKER_REGISTRY=generaltao725
COMPOSE_PROJECT_NAME=sinair-llm-bot-test
POSTGRES_USER=d
POSTGRES_PASSWORD=d
POSTGRES_DB=sinair_llm_bot_db
POSTGRES_APP_USER=app
POSTGRES_APP_PASSWORD=app
POSTGRES_PORT=5432
POSTGRES_ADDRESS=db

GOOGLE_CLIENT_ID=stub-google-client-id
GOOGLE_CLIENT_SECRET=stub-google-client-secret
SERVER_SERVLET_SESSION_COOKIE_DOMAIN=127.0.0.1
SERVER_SERVLET_SESSION_COOKIE_NAME=JSESSIONID-TEST
APP_DEFAULT_SUCCESS_URL=http://127.0.0.1:3000
APP_LOGIN_URL=http://127.0.0.1:3000/login
CSRF_COOKIE_NAME=XSRF-TOKEN-LOCAL
SPRING_PROFILES_ACTIVE=postgres,stub-google,local,stub-llm

LOCAL_BACKEND_URL=http://backend:8080
PUBLIC_BACKEND_URL=http://127.0.0.1:8080

CHAT_WS_URL=wss://sinair.net/ws/chat
CHAT_API_KEY=test-api-key
CHAT_ROOMS=#test
BATCH_SIZE=10
BATCH_FLUSH_INTERVAL=5000

# --- Bot (backend) ---
BOT_ENABLED=true
BOT_ROOMS=#test

# LLM provider: the `stub-llm` profile routes calls to an in-process WireMock stub (port 9562).
# For prod, drop `stub-llm` from SPRING_PROFILES_ACTIVE and set LLM_API_KEY.

# --- Bot sending (collector) ---
BOT_SEND_ENABLED=true
OUTBOUND_POLL_INTERVAL=3000
